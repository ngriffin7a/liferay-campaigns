# ---------------------------------------------------------------------------
# .env.example – Environment variables for local campaigns-microservice runs
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# When deploying to Liferay PaaS, set these same variables in the
# service's "Environment Variables" section of the PaaS Console
# (Liferay Cloud Console → Service → Environment Variables).
#
# Every variable below is optional; each has a default in
# src/main/resources/application-default.properties. Override only what
# differs for your environment. Secrets (passwords) have no default and
# must be supplied here.
# ---------------------------------------------------------------------------

# CORS allowed origin patterns for browser callers of the microservice.
# Comma-separated list; supports wildcards via Spring's allowedOriginPatterns.
# Local dev default is "*". For PaaS, scope this to your Liferay host
# (e.g. https://*.lfr.cloud or https://webserver-<project>-prd.lfr.cloud).
CORS_ALLOWED_ORIGIN_PATTERNS=*

# Liferay DXP base URL and admin credentials used by the campaign scheduler
# (Basic Auth) and the DisplayPageUrlService startup load.
# Local dev: http://localhost:8080
# PaaS:      https://webserver-<project>-<env>.lfr.cloud
LIFERAY_BASE_URL=https://webserver-lctfootrial-prd.lfr.cloud
LIFERAY_EMAIL=test@liferay.com
LIFERAY_PASSWORD=

# Liferay headless API base URL (note the trailing "/o").
# Defaults to ${LIFERAY_BASE_URL}-equivalent; override if the API host differs.
LIFERAY_HEADLESS_API_BASE_URL=https://webserver-lctfootrial-prd.lfr.cloud/o

# Public-facing base URL used to build friendly URLs embedded in emails.
EMAIL_FRIENDLY_URL_BASE_URL=https://webserver-lctfootrial-prd.lfr.cloud

# Base URL of this microservice, used to build the email open-tracking pixel.
# Local dev: http://localhost:58081
# PaaS:      https://campaignsmicroservice-<project>-<env>.lfr.cloud/
TRACKING_PIXEL_BASE_URL=https://campaignsmicroservice-lctfootrial-prd.lfr.cloud/

# Shared secret used to encrypt the open-tracking pixel URL parameters (AES-GCM)
# so the recipient email address and campaign/content metadata are not exposed
# in cleartext, and the public pixel endpoint can reject forged/tampered events.
# Generate a long random value (e.g. `openssl rand -hex 32`) and keep it
# identical across all replicas of this microservice. When blank the endpoint
# fails closed and DROPS events unless TRACKING_PIXEL_ALLOW_UNSIGNED=true.
TRACKING_PIXEL_SECRET=

# Accept cleartext, unauthenticated events when no secret is set (the email
# address then appears in the URL). Defaults to false (fail closed). Set true
# ONLY for local development.
TRACKING_PIXEL_ALLOW_UNSIGNED=false

# How long a pixel token stays valid, in days (bounds replay). 0 disables the
# freshness check.
TRACKING_PIXEL_MAX_AGE_DAYS=90

# Spring Mail (SMTP) settings used to send campaign emails.
# SPRING_MAIL_PASSWORD must be supplied (no default).
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=noreply@example.com
SPRING_MAIL_PASSWORD=

# Analytics Cloud (Asah) publisher endpoint and identifiers.
# Find PROJECT_ID via the OSB-Asah-Project-ID header on Analytics XHR requests;
# find DATASOURCE_ID / CHANNEL_ID in the JSON payload of the same XHR request
# (browser Network tab).
# Log level for this microservice's own packages. Defaults to INFO; set to
# DEBUG only in a controlled environment, as DEBUG emits PII-bearing analytics
# payloads and full tracking URLs.
CAMPAIGNS_LOG_LEVEL=INFO

ANALYTICS_ENDPOINT_URL=https://osbasahpublisher-ac-uswest1.lfr.cloud/
ANALYTICS_PROJECT_ID=
ANALYTICS_DATASOURCE_ID=
ANALYTICS_CHANNEL_ID=
